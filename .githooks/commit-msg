#!/bin/sh

set -eu

message_file="$1"
first_line="$(sed -n '1p' "$message_file" | tr -d '\r')"

if [ -z "$first_line" ]; then
  echo "提交信息不能为空。" >&2
  exit 1
fi

case "$first_line" in
  Merge\ *|Revert\ *)
    exit 0
    ;;
esac

if ! printf '%s\n' "$first_line" | grep -Eq '^(feat|fix|refactor|docs|chore|test|build|ci|perf|revert): .+'; then
  echo "提交信息格式不合法。" >&2
  echo "请使用中文前缀摘要，例如：feat: 新增批量发布功能" >&2
  echo "允许前缀：feat / fix / refactor / docs / chore / test / build / ci / perf / revert" >&2
  exit 1
fi

if ! printf '%s\n' "$first_line" | grep -Eq '[一-龥]'; then
  echo "提交信息摘要需使用中文。" >&2
  echo "示例：fix: 修复路由路径" >&2
  exit 1
fi
